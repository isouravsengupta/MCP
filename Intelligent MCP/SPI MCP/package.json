{
  "name": "spi-mcp",
  "version": "0.1.0",
  "description": "SPI MCP server for Snowflake-backed sales insights",
  "type": "module",
  "main": "dist/lambda.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "dev": "tsx src/lambda.ts",
    "start": "node dist/lambda.js",
    "check": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "ops:generate-context-index": "node ops/generate-context-index.mjs",
    "ops:generate-dashboard-catalog": "node ops/generate-dashboard-catalog.mjs",
    "ops:refresh-metric-artifacts": "node ops/refresh-metric-artifacts.mjs",
    "ops:refresh-all": "npm run ops:generate-context-index && npm run ops:generate-dashboard-catalog && npm run ops:refresh-metric-artifacts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1062.0",
    "@aws-sdk/s3-request-presigner": "^3.1062.0",
    "@modelcontextprotocol/sdk": "^1.13.1",
    "@napi-rs/canvas": "^1.0.0",
    "chart.js": "^4.5.1",
    "snowflake-sdk": "^2.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.143",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
