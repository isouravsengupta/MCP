# ── Snowflake connection ─────────────────────────────────────────────────────
SNOWFLAKE_ACCOUNT=myorg-myaccount
SNOWFLAKE_USER=svc_spi_mcp@salesforce.com     # service account email
SNOWFLAKE_WAREHOUSE=SPI_WH
SNOWFLAKE_DATABASE=SPI_DB
SNOWFLAKE_SCHEMA=SALES_PLANNING
SNOWFLAKE_ROLE=SPI_ANALYST_ROLE               # optional

# ── Auth mode ────────────────────────────────────────────────────────────────
# Use 'sso' for local development (opens browser), 'service_account' on Lambda
SNOWFLAKE_AUTH_MODE=sso

# ── Service account only (Lambda) ────────────────────────────────────────────
SNOWFLAKE_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:spi/snowflake-key

# ── MCP auth token (shared secret for Slack → Lambda calls) ─────────────────
MCP_AUTH_TOKEN=change-me-to-a-long-random-string
