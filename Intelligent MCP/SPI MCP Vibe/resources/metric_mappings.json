    {
      "id": "spm_total_acv",
      "name": "SPM Total ACV Influenced ($)",
      "description": "Sum of converted ACV amount on opportunities influenced by Sales Programmes. Source: GSP_SPM_ACV_PERM.",
      "sourceTable": "{DB}.AIO.GSP_SPM_ACV_PERM",
      "grain": "quarter",
      "dimensions": ["region", "segment", "program_name", "program_id", "program_type", "program_status", "fiscal_close_qtr", "fiscal_flip_qtr", "fiscal_close_year", "fiscal_flip_year", "program_owner"],
      "sqlTemplate": "SELECT SUM(OPTY_AMT_CONVT) AS \"Total ACV Influenced ($)\" FROM {DB}.AIO.GSP_SPM_ACV_PERM",
      "crmaFields": {
        "region":            "REGION",
        "segment":           "BB_DRVD_SEG_MACRO_NM_DISPLAY",
        "program_name":      "PROGRAM_NAME",
        "program_id":        "PROGRAM_ID",
        "program_type":      "PROGRAM_TYPE",
        "program_status":    "PROGRAM_STATUS",
        "fiscal_close_qtr":  "FISCAL_CLOSE_YR_QTR_NM",
        "fiscal_flip_qtr":   "FISCAL_FLIP_YR_QTR_NM",
        "fiscal_close_year": "FISCAL_CLOSE_YEAR",
        "fiscal_flip_year":  "FISCAL_FLIP_YEAR",
        "program_owner":     "PROGRAM_OWNER_NAME"
      },
      "snowflakeColumns": {
